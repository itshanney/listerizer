[Unit]
Description=listerizer
After=syslog.target network.target

[Service]
User=listerizer
Group=listerizer

Environment="JAVA_HOME=/usr/lib/jvm/java-25-openjdk-amd64"

ExecStart=/usr/lib/jvm/java-25-openjdk-amd64/bin/java -jar /var/lib/listerizer/listerizer.jar --spring.config.additional-location=/var/lib/listerizer/config/application.properties
ExecStop=/bin/kill -15 $MAINPID
SuccessExitStatus=143

[Install]
WantedBy=multi-user.target