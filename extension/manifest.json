{
  "manifest_version": 3,
  "name": "Listerizer",
  "version": "1.2",
  "description": "Chrome extension to sync with the Listerizer API",
  "permissions": [
    "readingList"
  ],
  "host_permissions": [
    "https://listerizer.brickfolio.dev/*"
  ],
  "action": {
    "default_title": "Export Reading List"
  },
  "background": {
    "service_worker": "background.js"
  }
}