{
  "manifest_version": 3,
  "name": "Reading List Exporter",
  "version": "1.0",
  "description": "Export your Chrome Reading List to JSON.",
  "permissions": [
    "readingList"
  ],
  "action": {
    "default_title": "Export Reading List"
  },
  "background": {
    "service_worker": "background.js"
  }
}
